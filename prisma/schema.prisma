// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgType {
  NONPROFIT
  FOUNDATION
  GRASSROOTS
  GOVERNMENTAL
  FAITH_BASED
  PTA
}

enum ImpactScope {
  HYPERLOCAL  // e.g., neighborhood or community
  LOCAL       // city / county
  REGIONAL    // multi-city or multi-county
  STATE       // state-level
  NATIONAL    // country-level
  INTERNATIONAL
}

enum AreaType {
  NEIGHBORHOOD
  CITY
  COUNTY
  STATE
  COUNTRY
}

model User {
  id              Int     @id @default(autoincrement())
  email           String? @unique
  phoneNumber     String? @unique
  passwordHash    String?
  oauthProvider   String?
  oauthProviderId String?
  authMethod      String  @default("email")

  emailVerified     Boolean @default(false)
  verificationToken String? @unique
  name     String?
  username String? @unique
  bio      String?
  imageUrl String?

  roles Role[]

  accounts  Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundraisers        Fundraiser[]
  donations          Donation[]
  events             Event[]
  auditLogs          AuditLog[]
  comments           Comment[]
  recurringDonations RecurringDonation[]
}

enum Role {
  USER
  ADMIN
  ORG_MANAGER
  DONOR
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  provider          String
  providerAccountId String
  type              String
  access_token      String?
  expires_at        Int?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Organization {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String?  @unique
  type         OrgType?
  description  String?
  category     String?
  websiteUrl   String?
  brandColor   String?
  founded      DateTime?
  instagram    String?
  tiktok       String?

  imageUrl     String?
  contactEmail String?

  // Impact / location-ish data (kept for backwards compat, superseded by serviceAreas)
  impactScope  ImpactScope?
  impactAreas  Json?

  // Tags relation (many-to-many)
  tags Tag[]

  // Service areas (one-to-many)
  serviceAreas ServiceArea[]

  // Regulatory ID Information
  regulatoryId     String? @unique
  regulatoryIdType String?
  countryCode      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundraisers        Fundraiser[]
  donations          Donation[]
  detail             OrgDetail?
  events             Event[]
  payouts            Payout[]
  recurringDonations RecurringDonation[]
}

model ServiceArea {
  id      Int      @id @default(autoincrement())
  orgId   Int
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  type    AreaType // NEIGHBORHOOD, CITY, COUNTY, STATE, COUNTRY
  value   String   // canonical name: "Ballard", "Seattle", "King County", "Washington", "United States"
  placeId String?  // external reference ID for boundary lookup (e.g. "census:53033", "osm:123456")

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([value])
}

model OrgDetail {
  id             Int     @id @default(autoincrement())
  mission        String?
  history        String?
  impactStats    Json?
  testimonials   Json?
  additionalInfo Json?
  nteeCode       String?
  rulingDate     String?
  city           String?
  state          String?
  zipcode        String?
  address        String?

  orgId        Int          @unique
  organization Organization @relation(fields: [orgId], references: [id])
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  emoji     String?
  color     String?
  createdAt DateTime @default(now())

  organizations Organization[]

  @@map("Tag")
  @@unique([name, slug])
}

model Fundraiser {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  goalAmount    Float
  currentAmount Float     @default(0)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId        Int
  organization Organization @relation(fields: [orgId], references: [id])

  creatorId Int
  creator   User @relation(fields: [creatorId], references: [id])

  coHosts Int[]

  donations Donation[]
  events    Event[]
  comments  Comment[]
}

model Donation {
  id       Int    @id @default(autoincrement())
  amount   Float
  currency String @default("USD")

  paymentIntentId String @unique
  status          String @default("pending")

  description   String?
  dedication    String?
  anonymous     Boolean @default(false)
  paymentMethod String?

  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  fundraiserId Int?
  fundraiser   Fundraiser? @relation(fields: [fundraiserId], references: [id])

  orgId        Int
  organization Organization @relation(fields: [orgId], references: [id])

  events Event[]
}

model Event {
  id Int @id @default(autoincrement())

  type      EventType
  content   String
  timestamp DateTime  @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  orgId        Int?
  organization Organization? @relation(fields: [orgId], references: [id])

  fundraiserId Int?
  fundraiser   Fundraiser? @relation(fields: [fundraiserId], references: [id])

  donationId Int?
  donation   Donation? @relation(fields: [donationId], references: [id])
}

enum EventType {
  NEW_FUNDRAISER
  DONATION
  NEW_ORG
  USER_JOINED
  FUNDRAISER_COMPLETED
}

model AuditLog {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  action    String
  details   Json?
  timestamp DateTime @default(now())
}

model Comment {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  fundraiserId Int
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id])

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payout {
  id Int @id @default(autoincrement())

  orgId        Int
  organization Organization @relation(fields: [orgId], references: [id])

  amount        Float
  status        String  @default("pending")
  transactionId String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model RecurringDonation {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  orgId        Int
  organization Organization @relation(fields: [orgId], references: [id])

  amount               Float
  currency             String  @default("USD")
  interval             String
  status               String  @default("active")
  stripeSubscriptionId String?

  createdAt        DateTime  @default(now())
  nextDonationDate DateTime?
}